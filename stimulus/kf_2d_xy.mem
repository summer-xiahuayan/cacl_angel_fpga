// 3.2 计算 S^{-1} 的分子项 [S22, -S12; -S21, S11]
// (S_inv11_num = S22)
// (S_inv12_num = -S12)
// (S_inv21_num = -S21)
// (S_inv22_num = S11)


// 3.3 计算 K = (P^-H^T) * S^{-1} 分子项 (先不除det_S)
// K11 = PH11*S_inv11_num + PH12*S_inv21_num=PH11*S22-PH12*S21
DF8A  // PC=140: MUL DB[24]*DB[31] (PH11*S22)
E801  // PC=141: Store -> DB[7] (term1)
E7CA  // PC=142: MUL DB[25]*DB[30] (PH12*S21)
F001  // PC=143: Store -> DB[8] (term2)
F786  // PC=144: SUB DB[7]-DB[8] (K11_num)
F801  // PC=145: Store -> DB[7] (K11_num)

// K12 = PH11*S_inv12_num + PH12*S_inv22_num=PH12*S11-PH11*S12
DFCA  // PC=146: MUL DB[24]*DB[29] (PH11*S12)
F001  // PC=147: Store -> DB[8] (term1)
E78A  // PC=148: MUL DB[25]*DB[28] (PH12*S11)
F801  // PC=149: Store -> DB[9] (term2)
FF86  // PC=150: SUB DB[8]-DB[9] (K12_num)
C001  // PC=151: Store -> DB[8] (K12_num)

// K21 = PH21*S_inv11_num + PH22*S_inv21_num=PH21*S22-PH22*S21
EF8A  // PC=152: MUL DB[26]*DB[31] (PH21*S22)
F801  // PC=153: Store -> DB[9] (term1)
F7CA  // PC=154: MUL DB[27]*DB[30] (PH22*S21)
B001  // PC=155: Store -> DB[10] (term2)
BD86  // PC=156: SUB DB[9]-DB[10] (K21_num)
D001  // PC=157: Store -> DB[9] (K21_num)

// K22 = PH21*S_inv12_num + PH22*S_inv22_num=PH22*S11-PH21*S12
EFCA  // PC=158: MUL DB[26]*DB[29] (PH21*S12)
B001  // PC=159: Store -> DB[10] (term1)
F78A  // PC=160: MUL DB[27]*DB[28] (PH22*S11)
B801  // PC=161: Store -> DB[11] (term2)
BF86  // PC=162: SUB DB[10]-DB[11] (K22_num)
D801  // PC=163: Store -> DB[10] (K22_num)

// 3.4 除以det_S得到最终K矩阵
DF5E  // PC=164: DIV DB[7]/DB[6] WAIT (K11 = K11_num/det_S)
C001  // PC=165: Store -> DB[9] (K11)
E75E  // PC=166: DIV DB[8]/DB[6] WAIT (K12 = K12_num/det_S)

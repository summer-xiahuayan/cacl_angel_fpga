// kf_2d_2meas_corrected.mem - 2D Kalman Filter (2状态+2测量，修正矩阵求逆)
// n=2 states (pos1/位置1, pos2/位置2), r=2 measurements (x/y)
// 核心修正：卡尔曼增益K计算改为「矩阵求逆+矩阵乘法」，而非逐元素除法
// Memory Layout (关键地址标注):
//   DB[0-1]   = pos1,pos2 (2状态)
//   DB[2-5]   = P (2x2协方差: p11,p12,p21,p22)
//   DB[6-9]   = Phi (2x2状态转移矩阵: phi11,phi12,phi21,phi22)
//   DB[10-13] = Q (2x2过程噪声: q11,q12,q21,q22)
//   DB[14-17] = H (2x2观测矩阵: h11,h12,h21,h22)
//   DB[18-19] = R (2x2测量噪声: r11,r22，对角矩阵)
//   DB[20-21] = z (2测量值: z1=x, z2=y)
//   DB[22-31] = temps (临时计算区，避免覆盖关键数据)

// ==== 1. 初始化：加载24个参数 ====
// ==== 2. 时间更新：x^- = Phi*x (无控制输入G*u) ====
// ==== 3. 时间更新：P^- = Phi*P*Phi^T + Q ====
// ==== 4. 测量更新：计算 K = P^-*H^T * S^{-1}====   S = H*P^-*H^T + R (2×2)
// ==== 5. 状态更新：x^+ = x^- + K*(z - H*x^-) ====
// ==== 6. 协方差更新：P^+ = (I - K*H)*P^- ====

// ==== 1. 初始化：加载24个参数 ====
0001  // PC=0: Load -> DB[0] (pos1)
0801  // PC=1: Load -> DB[1] (pos2)
1001  // PC=2: Load -> DB[2] (p11)
1801  // PC=3: Load -> DB[3] (p12)
2001  // PC=4: Load -> DB[4] (p21)
2801  // PC=5: Load -> DB[5] (p22)
7001  // PC=14: Load -> DB[14] (h11)
7801  // PC=15: Load -> DB[15] (h12)
8001  // PC=16: Load -> DB[16] (h21)
8801  // PC=17: Load -> DB[17] (h22)
9001  // PC=18: Load -> DB[18] (r11)
9801  // PC=19: Load -> DB[19] (r22)

3001  // PC=6: Load -> DB[6] (phi11)
3801  // PC=7: Load -> DB[7] (phi12)
4001  // PC=8: Load -> DB[8] (phi21)
4801  // PC=9: Load -> DB[9] (phi22)
5001  // PC=10: Load -> DB[10] (q11)
5801  // PC=11: Load -> DB[11] (q12)
6001  // PC=12: Load -> DB[12] (q21)
6801  // PC=13: Load -> DB[13] (q22)
A001  // PC=20: Load -> DB[20] (z1=x)
A801  // PC=21: Load -> DB[21] (z2=y)

// ==== 2. 时间更新：x^- = Phi*x (无控制输入G*u) ====
// pos1^- = phi11*pos1 + phi12*pos2
300A  // PC=22: MUL DB[6]*DB[0] (phi11*pos1)
B001  // PC=23: Store -> DB[22] 
384A  // PC=24: MUL DB[7]*DB[1] (phi12*pos2)
B801  // PC=25: Store -> DB[23] 
BE03  // PC=26: ADD DB[22]+DB[23] in-place (pos1^- → DB[22])
// pos2^- = phi21*pos1 + phi22*pos2
400A  // PC=27: MUL DB[8]*DB[0] (phi21*pos1)
B801  // PC=28: Store -> DB[23] 
484A  // PC=29: MUL DB[9]*DB[1] (phi22*pos2)
C001  // PC=30: Store -> DB[24] 
C643  // PC=31: ADD DB[23]+DB[24] in-place (pos2^- → DB[23])

// ==== 3. 时间更新：P^- = Phi*P*Phi^T + Q ====

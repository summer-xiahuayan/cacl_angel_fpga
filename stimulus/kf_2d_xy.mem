// Step 3: 计算 S的逆矩阵 S^{-1} (核心修正)
// 3.1 计算行列式 det(S) = S11*S22 - S12*S21
DF0A  // PC=128: MUL DB[28]*DB[31] (S11*S22)
E001  // PC=129: Store -> DB[6] (temp1)
E74A  // PC=130: MUL DB[29]*DB[30] (S12*S21)
E801  // PC=131: Store -> DB[7] (temp2)
EC46  // PC=132: SUB DB[6]-DB[7] (det(S))
